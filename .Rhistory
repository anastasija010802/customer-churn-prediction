data <- read.csv("churn telekom (1).csv", stringsAsFactors = FALSE)
str(data)
apply(data, 2, FUN= function(x) sum(is.na(x)))
apply(data, 2, FUN= function(x) sum(x=="", na.rm = TRUE))
apply(data, 2, FUN= function(x) sum(x==" ", na.rm = TRUE))
apply(data, 2, FUN= function(x) sum(x=="-", na.rm = TRUE))
#u datasetu ne postoje nedostajuce vrednosti, sto znaci da nema opservacjia koje ce se anulirati
#ili opservacija kojjo ce se za odredjeni atribur dodeliti vrednost
length(unique(data$State))
#ima 51 razlicitu vrednost sto smatram da na skupu od 3333 opservacija je skroz u redu
#pretvoriti u faktor i zadrzati u analizi
data_arranged<- data
data_arranged$State<- as.factor(data$State)
length(unique(data$Account.Length))
length(unique(data$Area.Code))
#area code je tipa numeric ali uocava se da ona ima svega tri trazlicite vrednosti pa bi se
#radi bolje analize trebala pretvoriti u faktor
data_arranged$Area.Code <- as.factor(data_arranged$Area.Code)
length(unique(data$Phone))
#phone varijabla u ovom slucaju ne znaci nista, i moze se reci da predstavlja jedinstveni identifikator
#jer je broj razlicitih vrednosti ove varijable jednak broju opservacija u datasetu,
#moze se ukloniti
data_arranged <- subset(data, select = - Phone)
str(data_arranged)
length(unique(data_arranged$Int.l.Plan))
#int.l.plan bi trebalo pretvoriti u faktorsku, dodeljujem joj levele jer najcesce kao referentnu korisim negativnu vrednost
data_arranged$Int.l.Plan<- factor(data_arranged$Int.l.Plan, levels = c("no","yes") )
length(unique(data_arranged$VMail.Plan))
#isto vazi i za vmail.plan
data_arranged$VMail.Plan<- factor(data_arranged$VMail.Plan, levels = c("no","yes"))
length(unique(data_arranged$Intl.Calls))
length(unique(data_arranged$CustServ.Calls))
class(data_arranged$Churn.)
#izlazna varijabla mora biti faktorska
data_arranged$Churn. <- factor(data$Churn., levels = c("False.","True."))
str(data_arranged)
prop.table(table(data$Churn.))
#prema pocetnim podacima, moze se uociti da je procenat onih koji ne odlaze iz kompanije ~85%
#dok je procenat onih koji odlaze ~15%
#stablo odlucivanja
str(data_arranged)
#ulazne varijable moraju biti numerickog ili faktorskog tipa, dok je izlazna faktor
#vizualizacijom se mogu odraditi dodatne analize kako bi se videlo da li je jos neku varijablu potrebno zadrzati ili izbaciti
library(ggplot2)
ggplot(data = data_arranged, mapping = aes(x=State, fill = Churn.))+ geom_bar(position = "dodge")
#ggplot daje neke varijacije, ali nije najjasniji pa je bolje odraditii statisticki test (Chi-square)
chisq.test(table(data_arranged$State, data_arranged$Churn.))
#signifikantnost testa iznosi 0.002, sto je manje od 0.05, dakle zakljucuje se da postoji
#statisticki znacajna razlika u state u odnosu na churn, zadrzavamo varijablu
ggplot(data = data_arranged, mapping = aes(x=Account.Length, fill = Churn.))+ geom_bar(position = "dodge")
#razlike u varijacijama postoje ali je za account lengtb >200 velicina uzorka jako malo,
#pa postoji verovatnoca da dodje do overfittinga
class(data_arranged$Account.Length)
shapiro.test(data_arranged$Account.Length[data_arranged$Churn.=="False."])
#promenljiva nema normalnu raspodelu kada je churn=false
shapiro.test(data_arranged$Account.Length[data_arranged$Churn.=="True."])
#medjutim u ovom slucaju raspodela je normalna, ali nulta hipoteza kaze da
#promenljive i za jednu i za drugu kategoriju churn moraju biti normalno rasporedjene
#tako da se obara nulta hipoteza i prihvata alternativna
wilcox.test(data_arranged$Account.Length~data_arranged$Churn.)
#test potvrdjuje nultu hipotezu, da nema statisticki znacajne razlike ali za sada cu je zadrzati
ggplot(data = data_arranged, mapping = aes(x=Area.Code, fill = Churn.))+ geom_bar(position = "dodge")
chisq.test(table(data_arranged$Area.Code, data_arranged$Churn.))
#za area code se vec sa grafika vidi da slicno varira churn u odnosu na pomenutu varijablu,
#trebalo bi razmisliti o njenom izbacivanju, pored toga prihvacena je nulta hipoteza da nema statisticki znacajne razlike
ggplot(data = data_arranged, mapping = aes(x=Int.l.Plan, fill = Churn.))+ geom_bar(position = "dodge")
ggplot(data = data_arranged, mapping = aes(x=VMail.Plan, fill = Churn.))+ geom_bar(position = "dodge")
chisq.test(table(data_arranged$VMail.Plan, data_arranged$Churn.))
#postoji statisticki znacajna razlika, zadrzavamo
ggplot(data = data_arranged, mapping = aes(x=VMail.Message, fill = Churn.))+ geom_bar(position = "dodge")
class(data_arranged$VMail.Message)
shapiro.test(data_arranged$VMail.Message[data_arranged$Churn.=="False."])
shapiro.test(data_arranged$VMail.Message[data_arranged$Churn.=="True."])
wilcox.test(data_arranged$VMail.Message~data_arranged$Churn.)
ggplot(data = data_arranged, mapping = aes(x=Day.Mins, fill = Churn.))+ geom_bar(position = "dodge")
ggplot(data = data_arranged, mapping = aes(x=Day.Calls, fill = Churn.))+ geom_bar(position = "dodge")
shapiro.test(data$Day.Calls[data_arranged$Churn.=="False."])
shapiro.test(data$Day.Calls[data_arranged$Churn.=="True."])
wilcox.test(data$Day.Calls~data$Churn., data = data)
#p vrednost je veca od 0.05 pa se zakljucuje da nema statisticki znacajne razlike, o njenom bi se izbacivanju trebalo razmisliti
ggplot(data = data_arranged, mapping = aes(x=Day.Charge, fill = Churn.))+ geom_bar(position = "dodge")
ggplot(data = data_arranged, mapping = aes(x=Eve.Mins, fill = Churn.))+ geom_bar(position = "dodge")
ggplot(data = data_arranged, mapping = aes(x=Eve.Calls, fill = Churn.))+ geom_bar(position = "dodge")
shapiro.test(data$Eve.Calls[data_arranged$Churn.=="False."])
shapiro.test(data$Eve.Calls[data_arranged$Churn.=="True."])
wilcox.test(data$Eve.Calls~data$Churn., data = data)
#Prihvata se nulta hipoteza da nema statisticki znacajne razlike, o njenom bi se izbacivanju trebalo razmisliti
ggplot(data = data_arranged, mapping = aes(x=Eve.Charge, fill = Churn.))+ geom_bar(position = "dodge")
ggplot(data = data_arranged, mapping = aes(x=Night.Mins, fill = Churn.))+ geom_bar(position = "dodge")
ggplot(data = data_arranged, mapping = aes(x=Night.Calls, fill = Churn.))+ geom_bar(position = "dodge")
shapiro.test(data$Night.Calls[data_arranged$Churn.=="False."])
shapiro.test(data$Night.Calls[data_arranged$Churn.=="True."])
t.test(data_arranged$Night.Calls~data_arranged$Churn.)
#takodje i o izbacivanju varijable night calls bi se trebalo razmisliti
ggplot(data = data_arranged, mapping = aes(x=Night.Charge, fill = Churn.))+ geom_bar(position = "dodge")
ggplot(data = data_arranged, mapping = aes(x=Intl.Mins, fill = Churn.))+ geom_bar(position = "dodge")
ggplot(data = data_arranged, mapping = aes(x=Intl.Calls, fill = Churn.))+ geom_bar(position = "dodge")
shapiro.test(data_arranged$Intl.Calls[data_arranged$Churn.=="False."])
shapiro.test(data_arranged$Intl.Calls[data_arranged$Churn.=="True."])
wilcox.test(data_arranged$Intl.Calls~data_arranged$Churn.)
ggplot(data = data_arranged, mapping = aes(x=Intl.Charge, fill = Churn.))+ geom_bar(position = "dodge")
ggplot(data = data_arranged, mapping = aes(x=CustServ.Calls, fill = Churn.))+ geom_bar(position = "dodge")
class(data_arranged$Day.Charge)
